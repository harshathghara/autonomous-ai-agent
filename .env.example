# Groq LLM (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily web search (https://tavily.com)
TAVILY_API_KEY=

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autonomous_agent
# Or set a full URL instead of DB_* vars:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/autonomous_agent

# Single-user ID until multi-user auth (Week 5)
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Fernet key for encrypting OAuth tokens at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Web UI server — python api/main.py or python -m api.main
API_HOST=localhost
API_PORT=8000

# Google OAuth (Gmail) — https://console.cloud.google.com/apis/credentials
# GOOGLE_REDIRECT_URI must match http://<API_HOST>:<API_PORT>/auth/callback (use localhost, not 127.0.0.1, for Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Gmail address for "mail me" (optional — falls back to connected Google account profile)
USER_EMAIL=

# Fallback timezone if Google Calendar timezone cannot be fetched (IANA name, e.g. UTC)
# Normally the agent reads your timezone from Google Calendar automatically.
USER_TIMEZONE=UTC

# Run Alembic migrations automatically when the API starts (true/false)
AUTO_MIGRATE=true

# PostgreSQL connection pool (asyncpg)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
